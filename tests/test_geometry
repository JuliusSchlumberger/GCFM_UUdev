
import geopandas as gpd
from shapely.geometry import Polygon
from ..src.geometry import pick_utm_crs, buffered_bbox, merge_geometries

def test_utm_zone_picker_for_mekong():
    gdf = gpd.GeoDataFrame(
        geometry=[Polygon([(105, 10), (106, 10), (106, 11), (105, 11)])],
        crs="EPSG:4326",
    )
    # Mekong delta is in UTM zone 48N
    assert pick_utm_crs(gdf) == "EPSG:32648"

def test_buffered_bbox_adds_buffer_in_meters():
    gdf = gpd.GeoDataFrame(
        geometry=[Polygon([(0, 0), (1, 0), (1, 1), (0, 1)])],
        crs="EPSG:4326",
    )
    _, bounds = buffered_bbox(gdf, buffer_m=10000, target_crs="EPSG:3857")
    width = bounds[2] - bounds[0]
    # Original ~111km wide at equator in EPSG:3857, plus 2*10km buffer
    assert width > 120_000
