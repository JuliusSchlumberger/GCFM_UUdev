include: "rules/06_river_network.smk"
include: "rules/07_boundary_forcings.smk"
include: "rules/08_clean_river_network.smk"
include: "rules/09a_river_depth.smk"
include: "rules/09b_estuarine_depth.smk"
include: "rules/10_condition_elevation.smk"
include: "rules/11_river_preburn.smk"
include: "rules/11b_burn_river_dem.smk"
include: "rules/12_testing.smk"
include: "rules/13_build_sfincs.smk"
include: "rules/14_run_spinup.smk"
include: "rules/15_sanity_checks.smk"
include: "rules/16_run_event.smk"

