# Snakefile

from snakemake.utils import min_version
min_version("7.0")

# ---- Configuration ----
configfile: "./config/config.yml"

# ---- Shared setup (catalogue helpers, wildcard constraints, etc.) ----
include: "rules/00_common.smk"

# ---- Rules ----
# Included in true DAG/topological order -- see each rule's own docstring
# for its actual predecessors/successors. Rules 09a/09b form one
# unconditional sequential chain (09b always runs right after 09a) -- rule 10
# is the actual independent branch, parallel to that chain. Both feed rule 11.
include: "rules/01_separate_deltas.smk"
include: "rules/02_modeldomain.smk"
include: "rules/03_land_polygons.smk"
include: "rules/04_protection_levels.smk"
