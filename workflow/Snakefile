_BUILD_OUTPUTS = [
    expand(results_path("{basin_id}/sfincs/sfincs.inp"), basin_id=BASINS),
    *(expand(results_path("{basin_id}/sfincs/sfincs.sbg"), basin_id=BASINS)
      if config["sfincs"]["subgrid"]["enabled"] else []),
    *(expand(results_path("{basin_id}/sfincs/spinup/" + RST_FNAME), basin_id=BASINS)
      + expand(results_path("{basin_id}/sfincs/spinup/validation_spinup.png"), basin_id=BASINS)
      + expand(results_path("{basin_id}/sfincs/spinup/sfincs_map.nc"), basin_id=BASINS)
      + expand(results_path("{basin_id}/sfincs/spinup/validation_max_inundation.png"), basin_id=BASINS)
      + expand(results_path("{basin_id}/sfincs/sanity/01_inundation_ratio.png"), basin_id=BASINS)
      if config["sfincs"]["rstart"]["enabled"] else []),
]

# ── Named partial-pipeline targets ───────────────────────────────────────────

rule preprocess:
    """
    Run only the preprocessing pipeline (rules 01–07):
    basin separation, domain, terrain & bathymetry, land use, roughness,
    boundary forcings, river network, depth, and validation.

    Usage:  snakemake preprocess --cores N
    """
    input: _PREPROCESS_OUTPUTS


rule build:
    """
    Run only the SFINCS model build and spinup restart (rules 08–09).
    Preprocessing outputs must already exist.

    Usage:  snakemake build --cores N
    """
    input: _BUILD_OUTPUTS


# ---- Default target ----
rule all:
    input: _PREPROCESS_OUTPUTS + _BUILD_OUTPUTS
