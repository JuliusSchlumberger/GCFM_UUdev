# ── Named partial-pipeline targets ───────────────────────────────────────────

rule preprocess:
    """
    Run only the preprocessing pipeline (rules 01–12):
    basin separation, domain, land polygons, protection levels, terrain &
    bathymetry, land use, roughness, river network, boundary forcings,
    network cleaning, depth, estuarine depth / river conditioning / preburn,
    and the upstream-boundary validation check.

    Usage:  snakemake preprocess --cores N
    """
    input: _PREPROCESS_OUTPUTS


rule build:
    """
    Run the SFINCS model build, spin-up, spin-up sanity checks, and the main
    flood-event simulation with its own sanity checks (rules 13–16).
    Preprocessing outputs must already exist.

    Usage:  snakemake build --cores N
    """
    input: _BUILD_OUTPUTS


# ---- Default target ----
rule all:
    input: _PREPROCESS_OUTPUTS + _BUILD_OUTPUTS
